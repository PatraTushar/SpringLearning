       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- your beans go here -->


    <bean id="order1" class="org.Example5.OrderInformation">

        <property name="orderID" value="12345"></property>
